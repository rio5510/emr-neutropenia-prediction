# =============================================================================
# FN-PRED-AI — .gitignore
# =============================================================================

# ---- Node / Frontend --------------------------------------------------------
node_modules/
dist/
dist-ssr/
*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---- Python / Backend -------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
.env

# ---- Model artifact (large binary — include explicitly if needed) -----------
# all_lgb_model.joblib

# ---- Editor / IDE -----------------------------------------------------------
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---- OS files ---------------------------------------------------------------
.DS_Store
Thumbs.db
